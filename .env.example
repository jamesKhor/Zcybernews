# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://zcybernews.com
NEXT_PUBLIC_SITE_NAME=ZCyberNews

# ─── Admin Panel Auth (NextAuth v5) ──────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://zcybernews.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password

# ─── AI Text Generation ──────────────────────────────────────────────────────
AI_PROVIDER=deepseek          # deepseek | kimi | openai

DEEPSEEK_API_KEY=              # https://platform.deepseek.com
KIMI_API_KEY=                  # https://platform.moonshot.cn (Kimi K2)
OPENAI_API_KEY=                # fallback / DALL-E 3 images

# ─── Web Search Enrichment ───────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=          # https://api.search.brave.com
# or: TAVILY_API_KEY=

# ─── Image Generation (Phase 5) ──────────────────────────────────────────────
FAL_KEY=                       # https://fal.ai — FLUX.1-schnell ~$0.003/img

# ─── GitHub Publishing ───────────────────────────────────────────────────────
# Fine-grained personal access token with contents: write permission
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=jamesKhor/Alecybernews   # owner/repo
GITHUB_BRANCH=main

# ─── WeChat Integration ──────────────────────────────────────────────────────
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=                  # for webhook signature verification
WECHAT_AUTO_PUSH=false         # set true to auto-push drafts to Official Account

# ─── Ads / Monetization ──────────────────────────────────────────────────────
# Google AdSense — get your publisher ID at https://adsense.google.com
NEXT_PUBLIC_ADSENSE_ID=              # ca-pub-XXXXXXXXXXXXXXXX
# Ad slot IDs (create in AdSense dashboard → Ads → By ad unit)
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=    # 300x250 sidebar rectangle
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=    # in-article responsive banner
NEXT_PUBLIC_ADSENSE_SLOT_FEED=       # in-feed ad for listing pages

# ─── Notifications (Telegram) ────────────────────────────────────────────────
# Get bot token from @BotFather on Telegram, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=              # 123456:ABC-DEF...
TELEGRAM_CHAT_ID=                # your personal chat ID (number)

# ─── Analytics ───────────────────────────────────────────────────────────────
PLAUSIBLE_DOMAIN=zcybernews.com

# ─── Deployment ──────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
