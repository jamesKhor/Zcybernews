{
  "name": "zcybernews",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "qa": "npm run typecheck && npm run test && npm run build",
    "qa:fast": "npm run typecheck && npm run test",
    "quality:audit": "tsx scripts/audit-published-quality.ts",
    "quality:audit:7d": "tsx scripts/audit-published-quality.ts --since=7d",
    "quality:audit:all": "tsx scripts/audit-published-quality.ts --all",
    "digest:preview": "tsx scripts/preview-digest.ts",
    "digest:preview:html": "tsx scripts/preview-digest.ts --html-only --window-hours=168",
    "backfill:iocs": "tsx scripts/backfill-iocs-ttps.ts",
    "backfill:iocs:apply": "tsx scripts/backfill-iocs-ttps.ts --apply",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@swc/helpers": "^0.5.21",
    "ai": "^6.0.154",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.9.1",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "p-limit": "^7.3.0",
    "pagefind": "^1.5.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "reading-time": "^1.5.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.11.0",
    "rss-parser": "^3.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
